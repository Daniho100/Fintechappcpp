#include <windows.h>
#include "resource.h"

IDD_LOGIN_DIALOG DIALOGEX 0, 0, 200, 100
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Login"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT "Username:", IDC_STATIC, 10, 10, 50, 8
    EDITTEXT IDC_USERNAME, 70, 10, 120, 12, ES_AUTOHSCROLL
    LTEXT "Password:", IDC_STATIC, 10, 30, 50, 8
    EDITTEXT IDC_PASSWORD, 70, 30, 120, 12, ES_PASSWORD | ES_AUTOHSCROLL
    DEFPUSHBUTTON "Login", ID_LOGIN, 70, 50, 50, 14
    PUSHBUTTON "Register", ID_REGISTER, 130, 50, 50, 14
    PUSHBUTTON "Cancel", IDCANCEL, 100, 70, 50, 14
END

IDD_REGISTER_DIALOG DIALOGEX 0, 0, 200, 100
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Register"
FONT 8, "MS Shell Dlg"
