IDD_BILL_DIALOG DIALOGEX 0, 0, 200, 100
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Pay Bill"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT "Type:", IDC_STATIC, 10, 10, 50, 8
    COMBOBOX IDC_BILL_TYPE, 70, 10, 120, 100, CBS_DROPDOWN | WS_VSCROLL
    LTEXT "Amount:", IDC_STATIC, 10, 30, 50, 8
    EDITTEXT IDC_AMOUNT, 70, 30, 120, 12, ES_AUTOHSCROLL | ES_NUMBER
    DEFPUSHBUTTON "OK", IDOK, 70, 50, 50, 14
    PUSHBUTTON "Cancel", IDCANCEL, 130, 50, 50, 14
END

IDD_FIXED_SAVE_DIALOG DIALOGEX 0, 0, 200, 120
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Create Fixed Saving"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT "Amount:", IDC_STATIC, 10, 10, 50, 8
    EDITTEXT IDC_AMOUNT, 70, 10, 120, 12, ES_AUTOHSCROLL | ES_NUMBER
    LTEXT "Rate (e.g., 0.07):", IDC_STATIC, 10, 30, 100, 8
    EDITTEXT IDC_INTEREST_RATE, 110, 30, 80, 12, ES_AUTOHSCROLL
    LTEXT "Days:", IDC_STATIC, 10, 50, 50, 8
    EDITTEXT IDC_DURATION_DAYS, 70, 50, 120, 12, ES_AUTOHSCROLL | ES_NUMBER
    DEFPUSHBUTTON "OK", IDOK, 70, 70, 50, 14
    PUSHBUTTON "Cancel", IDCANCEL, 130, 70, 50, 14
END

IDD_LOAN_DIALOG DIALOGEX 0, 0, 200, 120
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Take Loan"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT "Principal:", IDC_STATIC, 10, 10, 50, 8
    EDITTEXT IDC_AMOUNT, 70, 10, 120, 12, ES_AUTOHSCROLL | ES_NUMBER
    LTEXT "Interest Rate (e.g., 0.1):", IDC_STATIC, 10, 30, 100, 8
    EDITTEXT IDC_INTEREST_RATE, 110, 30, 80, 12, ES_AUTOHSCROLL
    LTEXT "Duration (days):", IDC_STATIC, 10, 50, 80, 8
    EDITTEXT IDC_DURATION_DAYS, 90, 50, 100, 12, ES_AUTOHSCROLL | ES_NUMBER
    DEFPUSHBUTTON "OK", IDOK, 70, 70, 50, 14
    PUSHBUTTON "Cancel", IDCANCEL, 130, 70, 50, 14
END

IDD_VIEW_LOANS_DIALOG DIALOGEX 0, 0, 300, 200
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Your Loans"
FONT 8, "MS Shell Dlg"
BEGIN
    CONTROL "", IDC_LOAN_LIST, "SysListView32", LVS_REPORT | LVS_SINGLESEL | WS_BORDER | WS_TABSTOP, 10, 10, 280, 150
    PUSHBUTTON "Close", IDOK, 120, 170, 50, 14
END

IDD_VIEW_FIXED_DIALOG DIALOGEX 0, 0, 300, 200
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
