IDD_MAIN_WINDOW DIALOGEX 0, 0, 320, 280
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Fintech Bank Dashboard"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT "Balance:", IDC_STATIC, 20, 20, 60, 10
    LTEXT "", IDC_BALANCE_LABEL, 90, 20, 150, 10
    LTEXT "Savings:", IDC_STATIC, 20, 40, 60, 10
    LTEXT "", IDC_SAVINGS_LABEL, 90, 40, 150, 10

    LTEXT "Your Account No:", IDC_STATIC, 20, 60, 80, 10
    EDITTEXT IDC_ACCOUNT_NUMBER, 110, 60, 150, 12, ES_AUTOHSCROLL | ES_READONLY

    GROUPBOX "Actions", IDC_STATIC, 10, 85, 300, 175

    PUSHBUTTON "Deposit", ID_DEPOSIT, 20, 105, 85, 25
    PUSHBUTTON "Withdraw", ID_WITHDRAW, 120, 105, 85, 25
    PUSHBUTTON "Pay Bill", ID_PAY_BILL, 220, 105, 85, 25

    PUSHBUTTON "Save to Savings", ID_SAVE, 20, 140, 85, 25
    PUSHBUTTON "Fixed Saving", ID_FIXED_SAVE, 120, 140, 85, 25
    PUSHBUTTON "Take Loan", ID_TAKE_LOAN, 220, 140, 85, 25

    PUSHBUTTON "View Loans", ID_VIEW_LOANS, 20, 175, 85, 25
    PUSHBUTTON "View Fixed", ID_VIEW_FIXED, 120, 175, 85, 25
    PUSHBUTTON "Transfer", ID_TRANSFER, 220, 175, 85, 25

    PUSHBUTTON "View History", ID_VIEW_HISTORY, 20, 210, 85, 25
    PUSHBUTTON "Logout", ID_LOGOUT, 220, 245, 85, 25
END



IDD_TRANSFER_DIALOG DIALOGEX 0, 0, 280, 140
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Transfer Money"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT "Your Account:", IDC_STATIC, 10, 10, 70, 8
    LTEXT "", IDC_SENDER_ACCOUNT, 90, 10, 180, 8
    LTEXT "Recipient Account No:", IDC_STATIC, 10, 30, 100, 8
    EDITTEXT IDC_RECIPIENT_ACCOUNT, 120, 30, 150, 12, ES_AUTOHSCROLL
    LTEXT "Amount:", IDC_STATIC, 10, 50, 50, 8
    EDITTEXT IDC_TRANSFER_AMOUNT, 120, 50, 150, 12, ES_AUTOHSCROLL | ES_NUMBER
    DEFPUSHBUTTON "Transfer", IDOK, 90, 80, 60, 14
    PUSHBUTTON "Cancel", IDCANCEL, 170, 80, 60, 14
END

IDD_HISTORY_DIALOG DIALOGEX 0, 0, 420, 250
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Transaction History"
FONT 8, "MS Shell Dlg"
BEGIN
    CONTROL "", IDC_HISTORY_LIST, "SysListView32", LVS_REPORT | LVS_SINGLESEL | WS_BORDER | WS_TABSTOP, 10, 10, 400, 200
    PUSHBUTTON "Close", IDOK, 180, 220, 60, 14
END

