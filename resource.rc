    LTEXT "Password:", IDC_STATIC, 10, 30, 50, 8
    EDITTEXT IDC_PASSWORD, 70, 30, 120, 12, ES_PASSWORD | ES_AUTOHSCROLL
    DEFPUSHBUTTON "Register", IDOK, 70, 50, 50, 14
    PUSHBUTTON "Cancel", IDCANCEL, 130, 50, 50, 14
END

